# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
SYNTHEA_CSV_DIR=output/csv

# AWS (Bronze)
S3_BUCKET=rwe-clinical-bronze-<you>
S3_PREFIX=bronze

# Snowflake
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=WH_DEV
SNOWFLAKE_DATABASE=RWE
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_STAGE=S3_BRONZE
